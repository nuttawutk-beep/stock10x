{
  "version": 2,
  "builds": [
    { "src": "api.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api.js" },
    { "src": "/landing", "dest": "/public/landing.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/thesis", "dest": "/public/thesis.html" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
